{
  "mcpServers": {
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "google-workspace": {
      "type": "http",
      "url": "http://127.0.0.1:8765/mcp"
    }
  }
}
