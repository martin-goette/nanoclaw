# Anthropic API key (injected into containers via credential proxy).
# Leave blank to use OAuth via ~/.claude/.credentials.json instead —
# recommended for Claude Max plan users so included quota is consumed
# rather than per-token API billing.
ANTHROPIC_API_KEY=

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Audio transcription (Slack voice clips)
OPENAI_API_KEY=
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Google Workspace MCP (Gmail, Calendar, Tasks, Drive, Docs, Sheets)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Minutes of idleness before an agent's SDK session is rotated to a fresh one.
# Rotation is lossless (old transcript is archived to conversations/). Default: 60.
SESSION_IDLE_TIMEOUT_MIN=60
